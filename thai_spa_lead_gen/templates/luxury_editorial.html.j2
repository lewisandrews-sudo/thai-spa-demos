<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ brand.business_name_en }} — {{ brand.tagline_en }}</title>
  <meta property="og:title" content="{{ brand.business_name_en }}">
  <meta property="og:description" content="{{ brand.tagline_en }} · {{ lead.area | title }}, Bangkok">
  <meta property="og:image" content="{{ brand.cover_photo_url }}">
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --brand-dark:   {{ brand.primary_color }};
      --accent:       {{ brand.accent_color }};
      --ivory:        #f7f4ef;
      --charcoal:     #1c1a17;
      --muted:        #7a7468;
      --rule:         #dedad3;
      --font-serif:   'Cormorant Garamond', Georgia, serif;
      --font-sans:    'Jost', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body { background: var(--ivory); color: var(--charcoal); font-family: var(--font-sans); font-weight: 300; line-height: 1.75; -webkit-font-smoothing: antialiased; }

    /* ─────────── NAV ─────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      padding: 0 60px;
      height: 72px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 0.5s, box-shadow 0.5s;
    }
    nav.solid {
      background: rgba(247,244,239,0.97);
      backdrop-filter: blur(8px);
      box-shadow: 0 1px 0 var(--rule);
    }
    .nav-logo {
      font-family: var(--font-serif); font-size: 1.05rem;
      letter-spacing: 3px; text-transform: uppercase;
      color: #fff; transition: color 0.5s; text-decoration: none;
    }
    nav.solid .nav-logo { color: var(--charcoal); }
    .nav-links { display: flex; gap: 40px; list-style: none; }
    .nav-links a {
      font-size: 0.68rem; letter-spacing: 3px; text-transform: uppercase;
      text-decoration: none; color: rgba(255,255,255,0.75);
      transition: color 0.3s;
    }
    nav.solid .nav-links a { color: var(--muted); }
    .nav-links a:hover, nav.solid .nav-links a:hover { color: var(--accent); }
    .nav-book {
      font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase;
      padding: 10px 26px; text-decoration: none;
      border: 1px solid rgba(255,255,255,0.5); color: #fff;
      transition: background 0.3s, color 0.3s, border-color 0.3s;
    }
    nav.solid .nav-book { border-color: var(--charcoal); color: var(--charcoal); }
    .nav-book:hover { background: var(--accent); border-color: var(--accent); color: #fff !important; }

    /* ─────────── HERO ─────────── */
    #hero {
      height: 100vh; min-height: 600px;
      position: relative; display: flex; align-items: flex-end;
      overflow: hidden;
    }
    .hero-img {
      position: absolute; inset: 0;
      background: url('{{ brand.cover_photo_url }}') center / cover no-repeat;
      transform: scale(1.08);
      animation: heroZoom 12s ease forwards;
    }
    .hero-veil {
      position: absolute; inset: 0;
      background: linear-gradient(
        160deg,
        {{ brand.primary_color }}22 0%,
        {{ brand.primary_color }}88 55%,
        {{ brand.primary_color }}ee 100%
      );
    }
    .hero-content {
      position: relative; z-index: 2;
      padding: 0 80px 90px;
      max-width: 860px;
    }
    .hero-eyebrow {
      font-size: 0.62rem; letter-spacing: 6px; text-transform: uppercase;
      color: var(--accent); margin-bottom: 18px;
      opacity: 0; animation: riseIn 0.9s 0.4s ease forwards;
    }
    .hero-name {
      font-family: var(--font-serif); font-size: clamp(2.8rem, 6vw, 5.5rem);
      font-weight: 300; line-height: 1.05; color: #fff;
      margin-bottom: 10px;
      opacity: 0; animation: riseIn 0.9s 0.6s ease forwards;
    }
    .hero-name em { font-style: italic; color: var(--accent); }
    .hero-tagline {
      font-size: 1rem; color: rgba(255,255,255,0.65);
      max-width: 460px; margin-bottom: 44px;
      opacity: 0; animation: riseIn 0.9s 0.8s ease forwards;
    }
    .hero-actions {
      display: flex; gap: 14px; flex-wrap: wrap;
      opacity: 0; animation: riseIn 0.9s 1s ease forwards;
    }
    .btn-accent {
      background: var(--accent); color: #fff;
      padding: 15px 38px; font-size: 0.68rem; letter-spacing: 3px;
      text-transform: uppercase; text-decoration: none; font-family: var(--font-sans);
      transition: opacity 0.2s;
    }
    .btn-accent:hover { opacity: 0.85; }
    .btn-outline-white {
      border: 1px solid rgba(255,255,255,0.45); color: rgba(255,255,255,0.85);
      padding: 15px 38px; font-size: 0.68rem; letter-spacing: 3px;
      text-transform: uppercase; text-decoration: none;
      transition: border-color 0.3s, color 0.3s;
    }
    .btn-outline-white:hover { border-color: var(--accent); color: var(--accent); }
    .hero-scroll {
      position: absolute; right: 56px; bottom: 40px; z-index: 2;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      opacity: 0; animation: fadeIn 1s 1.4s forwards;
    }
    .hero-scroll span {
      font-size: 0.52rem; letter-spacing: 4px; text-transform: uppercase;
      color: rgba(255,255,255,0.4); writing-mode: vertical-rl;
    }
    .hero-scroll-line {
      width: 1px; height: 52px;
      background: linear-gradient(to bottom, transparent, var(--accent));
      animation: pulse 2.4s infinite;
    }
    @keyframes heroZoom { to { transform: scale(1); } }
    @keyframes riseIn { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:none; } }
    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:1} }

    /* ─────────── SECTION BASE ─────────── */
    .section-wrap { padding: 100px 80px; }
    .section-wrap.wide { max-width: 1280px; margin: 0 auto; }
    .section-wrap.narrow { max-width: 960px; margin: 0 auto; }
    .eyebrow {
      font-size: 0.6rem; letter-spacing: 6px; text-transform: uppercase;
      color: var(--accent); margin-bottom: 14px;
    }
    .h2 {
      font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3.4rem);
      font-weight: 300; line-height: 1.15; color: var(--charcoal);
      margin-bottom: 20px;
    }
    .h2 em { font-style: italic; }
    .rule { width: 44px; height: 1px; background: var(--accent); margin: 18px 0 40px; }
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .reveal.in { opacity: 1; transform: none; }

    /* ─────────── ABOUT ─────────── */
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: center;
    }
    .about-body p { color: var(--muted); font-size: 0.975rem; margin-bottom: 18px; line-height: 1.85; }
    .about-stats {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 0; margin-top: 48px; padding-top: 40px;
      border-top: 1px solid var(--rule);
    }
    .stat { padding-right: 20px; border-right: 1px solid var(--rule); }
    .stat:last-child { border-right: none; padding-left: 20px; padding-right: 0; }
    .stat:not(:first-child) { padding-left: 20px; }
    .stat-n {
      font-family: var(--font-serif); font-size: 3rem;
      font-weight: 300; color: var(--charcoal); line-height: 1;
    }
    .stat-l { font-size: 0.6rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-top: 6px; }
    .about-imgs { position: relative; }
    .about-img-main { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; }
    .about-img-float {
      position: absolute; bottom: -32px; left: -32px;
      width: 55%; aspect-ratio: 1; object-fit: cover;
      outline: 6px solid var(--ivory);
    }

    /* ─────────── DIVIDER PHOTO ─────────── */
    .divider-photo {
      width: 100%; height: 480px;
      background: url('{{ brand.gallery_photos[0] if brand.gallery_photos else brand.cover_photo_url }}') center/cover no-repeat;
      position: relative;
    }
    .divider-photo-veil {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.35);
      display: flex; align-items: center; justify-content: center;
    }
    .divider-quote {
      font-family: var(--font-serif); font-size: clamp(1.4rem,3vw,2.2rem);
      font-weight: 300; font-style: italic; color: #fff;
      text-align: center; max-width: 680px; padding: 0 40px;
      line-height: 1.5;
    }

    /* ─────────── SERVICES ─────────── */
    .services-header { margin-bottom: 8px; }
    .service-row {
      display: grid; grid-template-columns: 40px 1fr auto;
      gap: 28px; align-items: start;
      padding: 36px 0; border-bottom: 1px solid var(--rule);
    }
    .service-row:first-of-type { border-top: 1px solid var(--rule); }
    .service-n {
      font-family: var(--font-serif); font-size: 0.9rem; color: var(--accent);
      padding-top: 6px; opacity: 0.9;
    }
    .service-info {}
    .service-name-th {
      font-family: var(--font-serif); font-size: 1.55rem; font-weight: 400;
      color: var(--charcoal); margin-bottom: 3px; line-height: 1.2;
    }
    .service-name-en {
      font-size: 0.62rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--accent); margin-bottom: 14px;
    }
    .service-desc { font-size: 0.88rem; color: var(--muted); line-height: 1.8; max-width: 500px; margin-bottom: 14px; }
    .service-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .stag {
      font-size: 0.58rem; letter-spacing: 1px; text-transform: uppercase;
      border: 1px solid var(--rule); padding: 4px 12px; color: var(--muted);
    }
    .service-right { text-align: right; padding-top: 6px; }
    .service-price {
      font-family: var(--font-serif); font-size: 1.8rem; font-weight: 300;
      color: var(--charcoal); display: block; line-height: 1;
    }
    .service-duration {
      font-size: 0.62rem; letter-spacing: 2px; text-transform: uppercase;
      color: var(--muted); display: block; margin-top: 6px;
    }
    .service-cta {
      display: inline-block; margin-top: 16px;
      font-size: 0.6rem; letter-spacing: 2px; text-transform: uppercase;
      color: var(--charcoal); text-decoration: none;
      border-bottom: 1px solid var(--charcoal);
      padding-bottom: 2px; transition: color 0.2s, border-color 0.2s;
      background: none; border-top:0; border-left:0; border-right:0;
      font-family: var(--font-sans); cursor: pointer;
    }
    .service-cta:hover { color: var(--accent); border-bottom-color: var(--accent); }

    /* ─────────── GALLERY ─────────── */
    .gallery-mosaic {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: 260px 260px;
      gap: 8px; margin-top: 48px;
    }
    .gm-item { overflow: hidden; }
    .gm-item img { width:100%; height:100%; object-fit:cover; display:block; transition: transform 0.7s ease; }
    .gm-item:hover img { transform: scale(1.05); }
    .gm-item:nth-child(1) { grid-column: 1 / 8; grid-row: 1 / 3; }
    .gm-item:nth-child(2) { grid-column: 8 / 13; grid-row: 1 / 2; }
    .gm-item:nth-child(3) { grid-column: 8 / 10; grid-row: 2 / 3; }
    .gm-item:nth-child(4) { grid-column: 10 / 13; grid-row: 2 / 3; }

    /* ─────────── REVIEWS ─────────── */
    .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 2px; margin-top: 48px; }
    .review-card {
      background: var(--ivory); border: 1px solid var(--rule);
      padding: 44px 36px; position: relative;
      transition: border-color 0.3s;
    }
    .review-card:hover { border-color: var(--accent); }
    .review-mark {
      font-family: var(--font-serif); font-size: 4.5rem; line-height: 1;
      color: var(--accent); opacity: 0.2;
      position: absolute; top: 24px; left: 30px;
    }
    .review-body {
      font-family: var(--font-serif); font-size: 1.05rem; font-style: italic;
      color: var(--charcoal); line-height: 1.75; margin-top: 28px;
    }
    .review-author {
      font-size: 0.62rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--muted); margin-top: 22px;
    }
    .review-stars { color: var(--accent); font-size: 0.75rem; letter-spacing: 3px; margin-top: 8px; }

    /* ─────────── BOOKING ─────────── */
    {{ booking_styles | default('') }}

    /* ─────────── CONTACT ─────────── */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .contact-item { margin-bottom: 36px; }
    .contact-label { font-size: 0.58rem; letter-spacing: 4px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
    .contact-value { font-size: 0.95rem; color: var(--muted); }
    .contact-value a { color: var(--muted); text-decoration: none; }
    .contact-value a:hover { color: var(--accent); }
    .map-frame { width:100%; aspect-ratio:4/3; }
    .map-frame iframe { width:100%; height:100%; border:none; filter: sepia(15%) contrast(1.1); }
    .line-pill {
      display: inline-flex; align-items: center; gap: 10px;
      background: #06c755; color: #fff; padding: 12px 24px;
      font-size: 0.68rem; font-weight: 500; letter-spacing: 1px;
      text-decoration: none; margin-top: 12px;
      transition: opacity 0.2s;
    }
    .line-pill:hover { opacity: 0.85; }

    /* ─────────── FOOTER ─────────── */
    footer {
      background: var(--brand-dark); color: rgba(255,255,255,0.5);
      padding: 52px 80px;
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-brand {
      font-family: var(--font-serif); font-size: 1rem; letter-spacing: 3px;
      text-transform: uppercase; color: rgba(255,255,255,0.85);
    }
    .footer-copy { font-size: 0.65rem; letter-spacing: 1px; }
    .footer-accent { color: var(--accent); }

    /* ─────────── RESPONSIVE ─────────── */
    @media (max-width: 960px) {
      .section-wrap { padding: 70px 28px; }
      nav { padding: 0 28px; }
      .hero-content { padding: 0 28px 70px; }
      .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 48px; }
      .about-img-float { display: none; }
      .nav-links { display: none; }
      footer { flex-direction: column; gap: 16px; text-align: center; padding: 40px 28px; }
      .gallery-mosaic { grid-template-rows: 200px 200px; }
    }
    @media (max-width: 600px) {
      .service-row { grid-template-columns: 1fr; gap: 0; }
      .service-right { text-align: left; padding-top: 16px; }
      .hero-scroll { display: none; }
      .gallery-mosaic { display: none; }
      .simple-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 32px; }
      .simple-gallery img { width:100%; aspect-ratio:1; object-fit:cover; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">{{ brand.business_name_en }}</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#find-us">Visit</a></li>
  </ul>
  <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="nav-book">
    {% if is_premium %}Reserve{% else %}Contact{% endif %}
  </a>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-img"></div>
  <div class="hero-veil"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">{{ lead.area | replace('_',' ') | title }} · Bangkok, Thailand</p>
    <h1 class="hero-name">{{ brand.business_name_th }}<br><em>{{ brand.tagline_en }}</em></h1>
    <p class="hero-tagline">{{ brand.about_text_en | truncate(130) }}</p>
    <div class="hero-actions">
      <a href="#services" class="btn-accent">Explore Treatments</a>
      <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="btn-outline-white">
        {% if is_premium %}Book Your Visit{% else %}Find Us{% endif %}
      </a>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="section-wrap wide">
    <div class="about-grid">
      <div class="about-body reveal">
        <p class="eyebrow">Our Story</p>
        <h2 class="h2">{{ brand.business_name_th }}<br><em>{{ brand.tagline }}</em></h2>
        <div class="rule"></div>
        <p>{{ brand.about_text_th }}</p>
        <p>{{ brand.about_text_en }}</p>
        <div class="about-stats">
          <div class="stat">
            <div class="stat-n">{{ lead.rating }}</div>
            <div class="stat-l">Google Rating</div>
          </div>
          <div class="stat">
            <div class="stat-n">{{ lead.review_count }}+</div>
            <div class="stat-l">Happy Guests</div>
          </div>
          <div class="stat">
            <div class="stat-n">{{ brand.services | length }}</div>
            <div class="stat-l">Treatments</div>
          </div>
        </div>
      </div>
      <div class="about-imgs reveal">
        <img class="about-img-main" src="{{ brand.gallery_photos[0] if brand.gallery_photos else brand.cover_photo_url }}" alt="{{ brand.business_name_en }}">
        {% if brand.gallery_photos | length > 1 %}
        <img class="about-img-float" src="{{ brand.gallery_photos[1] }}" alt="{{ brand.business_name_en }} interior">
        {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- DIVIDER PHOTO -->
{% if brand.gallery_photos | length > 2 %}
<div class="divider-photo" style="background-image: url('{{ brand.gallery_photos[2] }}')">
  <div class="divider-photo-veil">
    <p class="divider-quote">"{{ brand.tagline }}"</p>
  </div>
</div>
{% endif %}

<!-- SERVICES -->
<section id="services">
  <div class="section-wrap narrow">
    <div class="services-header reveal">
      <p class="eyebrow">Treatments & Wellness</p>
      <h2 class="h2">Our <em>Signature</em> Treatments</h2>
      <div class="rule"></div>
    </div>
    {% for service in brand.services %}
    <div class="service-row reveal">
      <div class="service-n">0{{ loop.index }}</div>
      <div class="service-info">
        <div class="service-name-th">{{ service.name_th }}</div>
        <div class="service-name-en">{{ service.name_en }}</div>
        {% if service.description %}
        <p class="service-desc">{{ service.description }}</p>
        {% endif %}
        {% if service.tags %}
        <div class="service-tags">{% for t in service.tags %}<span class="stag">{{ t }}</span>{% endfor %}</div>
        {% endif %}
      </div>
      <div class="service-right">
        <span class="service-price">฿{{ service.price_thb | int }}</span>
        <span class="service-duration">{{ service.duration_min }} min</span>
        <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="service-cta">
          {% if is_premium %}Reserve{% else %}Contact Us{% endif %}
        </a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- GALLERY -->
{% if brand.gallery_photos | length >= 3 %}
<section id="gallery">
  <div class="section-wrap wide">
    <div class="reveal">
      <p class="eyebrow">Gallery</p>
      <h2 class="h2">Our <em>Space</em></h2>
      <div class="rule"></div>
    </div>
    {% set photos = ([brand.cover_photo_url] + brand.gallery_photos)[:4] %}
    <div class="gallery-mosaic">
      {% for p in photos %}
      <div class="gm-item reveal"><img src="{{ p }}" alt="{{ brand.business_name_en }}" loading="lazy"></div>
      {% endfor %}
    </div>
    <div class="simple-gallery">
      {% for p in photos %}<img src="{{ p }}" alt="{{ brand.business_name_en }}" loading="lazy">{% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- REVIEWS -->
{% if brand.top_reviews %}
<section id="reviews">
  <div class="section-wrap wide">
    <div class="reveal">
      <p class="eyebrow">Guest Experiences</p>
      <h2 class="h2">What Our <em>Guests</em> Say</h2>
      <div class="rule"></div>
    </div>
    <div class="reviews-grid">
      {% for r in brand.top_reviews %}
      <div class="review-card reveal">
        <span class="review-mark">"</span>
        <p class="review-body">{{ r.text }}</p>
        <p class="review-author">— {{ r.author }}</p>
        <p class="review-stars">{% for i in range(r.rating) %}★{% endfor %}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- BOOKING (premium only) -->
{{ booking_section | default('') }}

<!-- CONTACT -->
<section id="find-us">
  <div class="section-wrap wide">
    <div class="reveal">
      <p class="eyebrow">Visit Us</p>
      <h2 class="h2">Find <em>Us</em></h2>
      <div class="rule"></div>
    </div>
    <div class="contact-grid">
      <div class="reveal">
        {% if lead.address %}
        <div class="contact-item">
          <div class="contact-label">Address</div>
          <div class="contact-value">{{ lead.address }}</div>
        </div>
        {% endif %}
        {% if brand.bts_mrt %}
        <div class="contact-item">
          <div class="contact-label">BTS / MRT</div>
          <div class="contact-value">{{ brand.bts_mrt }}</div>
        </div>
        {% endif %}
        {% if lead.phone %}
        <div class="contact-item">
          <div class="contact-label">Telephone</div>
          <div class="contact-value"><a href="tel:{{ lead.phone }}">{{ lead.phone }}</a></div>
        </div>
        {% endif %}
        <div class="contact-item">
          <div class="contact-label">Hours</div>
          {% for h in lead.opening_hours.weekday_text %}
          <div class="contact-value">{{ h }}</div>
          {% endfor %}
        </div>
        {% if brand.line_id %}
        <div class="contact-item">
          <div class="contact-label">LINE</div>
          <div class="contact-value">{{ brand.line_id }}</div>
          <a href="https://line.me/R/ti/p/{{ brand.line_id }}" class="line-pill" target="_blank">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 2.94 0 6.57c0 3.24 2.88 5.95 6.77 6.48.26.06.62.17.71.4.08.2.05.52.02.72l-.11.69c-.03.2-.16.77.67.42.84-.36 4.52-2.66 6.16-4.56C15.4 9.26 16 8 16 6.57 16 2.94 12.42 0 8 0z"/></svg>
            Chat on LINE
          </a>
        </div>
        {% endif %}
      </div>
      <div class="map-frame reveal">
        <iframe src="{{ brand.google_maps_embed_url }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <span class="footer-brand">{{ brand.business_name_en }}</span>
  <span class="footer-copy">© 2025 {{ brand.business_name_en }}. All rights reserved.</span>
  <span class="footer-accent">{{ lead.area | replace('_',' ') | title }}, Bangkok</span>
</footer>

<script>
  // Nav solid on scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav.classList.toggle('solid', scrollY > 60), { passive: true });

  // Scroll reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('in'), i * 70);
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
{{ booking_scripts | default('') }}
</body>
</html>
