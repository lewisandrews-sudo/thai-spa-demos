<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ brand.business_name_en }}</title>
  <meta property="og:title" content="{{ brand.business_name_en }}">
  <meta property="og:description" content="{{ brand.services[:2] | map(attribute='name_en') | join(' • ') }} • {{ lead.area | title }} • จองออนไลน์ได้เลย">
  <meta property="og:image" content="{{ brand.cover_photo_url }}">
  <meta property="og:url" content="{{ deploy_url }}">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary:    {{ brand.primary_color }};
      --secondary:  {{ brand.secondary_color }};
      --accent:     {{ brand.accent_color }};
      --text:       {{ brand.text_color }};
      --text-muted: rgba(255,255,255,0.65);
      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body:    'Montserrat', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--primary); color: var(--text); font-family: var(--font-body); font-weight: 300; line-height: 1.7; }
    nav { position: fixed; top: 0; width: 100%; z-index: 100; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(to bottom, rgba(0,0,0,0.6), transparent); }
    .nav-logo { font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); }
    .nav-cta { background: var(--accent); color: var(--primary); padding: 10px 24px; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; text-decoration: none; }
    #hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 80px 24px 40px; position: relative; background: url('{{ brand.cover_photo_url }}') center/cover no-repeat; }
    #hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(10,10,30,0.88) 100%); }
    .hero-content { position: relative; z-index: 1; max-width: 700px; }
    .hero-eyebrow { font-size: 0.7rem; letter-spacing: 5px; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
    .hero-title { font-family: var(--font-display); font-size: clamp(2.5rem, 8vw, 5rem); line-height: 1.1; margin-bottom: 12px; }
    .hero-title em { color: var(--accent); font-style: italic; }
    .hero-tagline { font-size: clamp(0.9rem, 2vw, 1.1rem); color: var(--text-muted); margin-bottom: 40px; }
    .hero-cta { display: inline-flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
    .btn-primary { background: var(--accent); color: var(--primary); padding: 14px 36px; font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; text-decoration: none; }
    .btn-outline { border: 1px solid var(--accent); color: var(--accent); padding: 14px 36px; font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase; text-decoration: none; }
    section { padding: 80px 24px; max-width: 1000px; margin: 0 auto; }
    .section-label { font-size: 0.65rem; letter-spacing: 5px; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
    .section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 5vw, 3rem); margin-bottom: 24px; }
    .divider { width: 60px; height: 1px; background: var(--accent); margin: 16px 0 32px; }
    #about p { color: var(--text-muted); font-size: 1rem; max-width: 640px; }
    #about p + p { margin-top: 12px; }
    #services { max-width: 1100px; }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
    .service-card { border: 1px solid rgba(255,255,255,0.1); padding: 28px 24px; transition: border-color 0.2s; }
    .service-card:hover { border-color: var(--accent); }
    .service-name-th { font-size: 1.1rem; font-family: var(--font-display); margin-bottom: 4px; }
    .service-name-en { font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 16px; }
    .service-meta { display: flex; justify-content: space-between; align-items: center; }
    .service-duration { font-size: 0.8rem; color: var(--text-muted); }
    .service-price { font-size: 1.3rem; font-family: var(--font-display); color: var(--accent); }
    .service-book { display: block; margin-top: 20px; text-align: center; background: transparent; border: 1px solid var(--accent); color: var(--accent); padding: 10px; font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; text-decoration: none; cursor: pointer; width: 100%; }
    .service-book:hover { background: var(--accent); color: var(--primary); }
    {{ booking_styles | default('') }}
    #gallery { max-width: 1100px; }
    .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 8px; margin-top: 32px; }
    .gallery-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; cursor: pointer; transition: opacity 0.2s; }
    .gallery-grid img:hover { opacity: 0.85; }
    .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 32px; }
    .review-card { border-left: 2px solid var(--accent); padding: 20px 20px 20px 24px; background: rgba(255,255,255,0.03); }
    .review-stars { color: var(--accent); font-size: 0.85rem; margin-bottom: 8px; }
    .review-text { font-size: 0.9rem; color: var(--text-muted); font-style: italic; margin-bottom: 12px; line-height: 1.6; }
    .review-author { font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }
    #find-us .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 32px; }
    #find-us iframe { width: 100%; height: 320px; border: none; }
    .contact-info { display: flex; flex-direction: column; gap: 16px; }
    .contact-item { display: flex; gap: 12px; align-items: flex-start; }
    .contact-item-icon { color: var(--accent); font-size: 1rem; flex-shrink: 0; margin-top: 2px; }
    .contact-item-text { font-size: 0.9rem; color: var(--text-muted); }
    .contact-item-text strong { color: var(--text); display: block; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 2px; }
    .line-btn { display: inline-block; background: #06c755; color: white; padding: 12px 24px; font-size: 0.8rem; font-weight: 600; text-decoration: none; margin-top: 8px; }
    footer { background: rgba(0,0,0,0.4); padding: 32px 40px; text-align: center; font-size: 0.8rem; color: var(--text-muted); }
    footer a { color: var(--accent); text-decoration: none; }
    @media (max-width: 640px) {
      nav { padding: 16px 20px; }
      .nav-cta { display: none; }
      #find-us .contact-grid { grid-template-columns: 1fr; }
      .hero-cta { flex-direction: column; align-items: center; }
    }
  </style>
</head>
<body>
<nav>
  <div class="nav-logo">{{ brand.business_name_en }}</div>
  <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="nav-cta">
    {% if is_premium %}จองนัด / Book{% else %}ติดต่อเรา / Contact{% endif %}
  </a>
</nav>
<section id="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">{{ lead.area | title }}, Bangkok</p>
    <h1 class="hero-title">{{ brand.business_name_th or brand.business_name_en }}<br><em>{{ brand.tagline_en }}</em></h1>
    <p class="hero-tagline">{{ brand.tagline or brand.about_text_en[:80] }}...</p>
    <div class="hero-cta">
      <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="btn-primary">
        {% if is_premium %}จองออนไลน์ / Book Now{% else %}ติดต่อเรา / Get in Touch{% endif %}
      </a>
      <a href="#services" class="btn-outline">บริการของเรา / Services</a>
    </div>
  </div>
</section>
<section id="about">
  <p class="section-label">เกี่ยวกับเรา</p>
  <h2 class="section-title">เกี่ยวกับเรา / About Us</h2>
  <div class="divider"></div>
  <p>{{ brand.about_text_th }}</p>
  <p>{{ brand.about_text_en }}</p>
</section>
<section id="services">
  <p class="section-label">บริการของเรา</p>
  <h2 class="section-title">บริการ / Services</h2>
  <div class="divider"></div>
  <div class="services-grid">
    {% for service in brand.services %}
    <div class="service-card">
      <div class="service-name-th">{{ service.name_th }}</div>
      <div class="service-name-en">{{ service.name_en }}</div>
      <div class="service-meta">
        <span class="service-duration">{{ service.duration_min }} นาที / min</span>
        <span class="service-price">฿{{ service.price_thb | int }}</span>
      </div>
      <a href="#{% if is_premium %}booking{% else %}find-us{% endif %}" class="service-book">
        {% if is_premium %}จองนัด / Book{% else %}ติดต่อ LINE / Contact{% endif %}
      </a>
    </div>
    {% endfor %}
  </div>
</section>
{{ booking_section | default('') }}
{% if brand.gallery_photos %}
<section id="gallery">
  <p class="section-label">แกลเลอรี่</p>
  <h2 class="section-title">ภาพบรรยากาศ / Gallery</h2>
  <div class="divider"></div>
  <div class="gallery-grid">
    {% for photo in brand.gallery_photos[:8] %}
    <img src="{{ photo }}" alt="{{ brand.business_name_en }} {{ loop.index }}" loading="lazy">
    {% endfor %}
  </div>
</section>
{% endif %}
{% if brand.top_reviews %}
<section id="reviews">
  <p class="section-label">รีวิวจากลูกค้า</p>
  <h2 class="section-title">รีวิว / Reviews</h2>
  <div class="divider"></div>
  <div class="reviews-grid">
    {% for review in brand.top_reviews %}
    <div class="review-card">
      <div class="review-stars">{% for _ in range(review.rating) %}★{% endfor %}</div>
      <p class="review-text">"{{ review.text }}"</p>
      <div class="review-author">— {{ review.author }}</div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}
<section id="find-us">
  <p class="section-label">ค้นหาเรา</p>
  <h2 class="section-title">ที่ตั้ง / Find Us</h2>
  <div class="divider"></div>
  <div class="contact-grid">
    <iframe src="{{ brand.google_maps_embed_url }}" allowfullscreen loading="lazy"></iframe>
    <div class="contact-info">
      <div class="contact-item">
        <span class="contact-item-icon">📍</span>
        <div class="contact-item-text">
          <strong>ที่อยู่ / Address</strong>{{ lead.address }}
          {% if brand.bts_mrt %}<br><em>{{ brand.bts_mrt }}</em>{% endif %}
        </div>
      </div>
      <div class="contact-item">
        <span class="contact-item-icon">📞</span>
        <div class="contact-item-text">
          <strong>โทร / Phone</strong><a href="tel:{{ lead.phone }}" style="color:inherit;">{{ lead.phone }}</a>
        </div>
      </div>
      {% if brand.line_id %}
      <div class="contact-item">
        <span class="contact-item-icon">💬</span>
        <div class="contact-item-text">
          <strong>LINE</strong>{{ brand.line_id }}
          <br><a href="https://line.me/ti/p/{{ brand.line_id | replace('@','') }}" class="line-btn">เพิ่มเพื่อน LINE / Add LINE</a>
        </div>
      </div>
      {% endif %}
      {% if lead.opening_hours.weekday_text %}
      <div class="contact-item">
        <span class="contact-item-icon">🕐</span>
        <div class="contact-item-text">
          <strong>เวลาเปิด / Hours</strong>
          {% for day in lead.opening_hours.weekday_text[:3] %}{{ day }}<br>{% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>
<footer>
  <p>© 2026 {{ brand.business_name_en }} • {{ brand.business_name_th }}</p>
  {% if lead.facebook_url %}<p style="margin-top:8px;"><a href="{{ lead.facebook_url }}">Facebook</a></p>{% endif %}
</footer>
{{ booking_scripts | default('') }}
</body>
</html>
