/* thai_spa_lead_gen/templates/booking_styles.css.j2 */
.booking-label { display:block; font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:var(--accent); margin-bottom:8px; margin-top:24px; }
.booking-input { width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:var(--text); padding:12px 16px; font-size:0.95rem; margin-bottom:4px; font-family:var(--font-body); outline:none; }
.booking-input:focus { border-color:var(--accent); }
.booking-input option { background: #1a1a2e; color: white; }
.time-slots-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:8px; margin-top:8px; }
.time-slot { padding:10px; text-align:center; border:1px solid rgba(255,255,255,0.15); cursor:pointer; font-size:0.85rem; transition:all 0.15s; }
.time-slot:hover { border-color:var(--accent); color:var(--accent); }
.time-slot.selected { background:var(--accent); color:var(--primary); border-color:var(--accent); }
.booking-summary { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); padding:16px; font-size:0.9rem; line-height:1.8; }
.hidden { display:none !important; }
.booking-step { margin-bottom: 8px; }
